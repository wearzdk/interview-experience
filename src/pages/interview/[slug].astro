---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
	const interviews = await getCollection('interviews');
	return interviews.map(entry => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={entry.data.title} description={`${entry.data.company} ${entry.data.position} 面经`} />
	</head>
	<body>
		<Header />
		<main>
			<article>
				<div class="breadcrumb">
					<a href="/">首页</a>
					<span>/</span>
					<a href={`/company/${entry.data.company}`}>{entry.data.company}</a>
					<span>/</span>
					<span>{entry.data.title}</span>
				</div>

				<div class="article-header">
					<h1>{entry.data.title}</h1>
					<div class="meta">
						<a href={`/company/${entry.data.company}`} class="company">{entry.data.company}</a>
						<span class="sep">·</span>
						<a href={`/position/${entry.data.position}`} class="position">{entry.data.position}</a>
						{entry.data.round && (
							<>
								<span class="sep">·</span>
								<span>{entry.data.round}</span>
							</>
						)}
						<span class="sep">·</span>
						<span class="date">{entry.data.date}</span>
					</div>
				</div>
				
				<div class="content">
					<Content />
				</div>

				<div class="article-footer">
					<a href="https://mianlingai.com" target="_blank" class="cta-banner">
						<div class="cta-content">
							<strong>面灵AI — AI实时面试助手</strong>
							<span>实时语音识别 + AI智能回答，帮你轻松应对各种面试场景</span>
						</div>
						<span class="cta-arrow">→</span>
					</a>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 800px;
		margin: 0 auto;
		padding: var(--space-md) 2rem var(--space-lg);
	}

	.breadcrumb {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.85rem;
		color: var(--color-muted);
		margin-bottom: var(--space-md);
	}

	.breadcrumb a:hover {
		color: var(--color-accent);
	}

	.article-header {
		margin-bottom: var(--space-md);
		padding-bottom: var(--space-md);
		border-bottom: 1px solid var(--color-border);
	}

	.article-header h1 {
		font-size: 1.75rem;
		font-weight: 700;
		margin-bottom: var(--space-sm);
		line-height: 1.3;
	}

	.meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.9rem;
		color: var(--color-muted);
	}

	.company, .position {
		font-weight: 600;
		color: var(--color-accent);
	}

	.company:hover, .position:hover {
		text-decoration: underline;
	}

	.sep {
		color: var(--color-border);
	}

	.content {
		line-height: 1.8;
		font-size: 0.95rem;
	}

	.content :global(h2) {
		font-size: 1.4rem;
		margin-top: var(--space-md);
		margin-bottom: var(--space-sm);
		font-weight: 700;
	}

	.content :global(h3) {
		font-size: 1.15rem;
		margin-top: 1.5rem;
		margin-bottom: var(--space-xs);
		font-weight: 600;
	}

	.content :global(p) {
		margin-bottom: var(--space-sm);
	}

	.content :global(ul), .content :global(ol) {
		margin: var(--space-sm) 0;
		padding-left: 1.5rem;
	}

	.content :global(li) {
		margin-bottom: 0.5rem;
	}

	.content :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin: var(--space-md) 0;
		font-size: 0.9rem;
	}

	.content :global(th), .content :global(td) {
		padding: 0.6rem 0.75rem;
		border: 1px solid var(--color-border);
		text-align: left;
	}

	.content :global(th) {
		background: var(--color-bg);
		font-weight: 600;
	}

	.content :global(strong) {
		font-weight: 600;
	}

	.content :global(hr) {
		border: none;
		border-top: 1px solid var(--color-border);
		margin: var(--space-md) 0;
	}

	.article-footer {
		margin-top: var(--space-lg);
		padding-top: var(--space-md);
		border-top: 1px solid var(--color-border);
	}

	.cta-banner {
		display: flex;
		justify-content: space-between;
		align-items: center;
		background: #fff5f0;
		border: 1px solid #ffd8c8;
		border-radius: 8px;
		padding: 1.25rem 1.5rem;
		transition: all 0.2s ease;
	}

	.cta-banner:hover {
		border-color: var(--color-accent);
		box-shadow: 0 4px 12px rgba(212, 56, 13, 0.1);
	}

	.cta-content {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.cta-content strong {
		color: var(--color-accent);
		font-size: 1rem;
	}

	.cta-content span {
		color: var(--color-muted);
		font-size: 0.85rem;
	}

	.cta-arrow {
		font-size: 1.5rem;
		color: var(--color-accent);
	}

	@media (max-width: 768px) {
		main { padding: var(--space-sm) 1rem; }
		.meta { flex-wrap: wrap; }
		.breadcrumb { flex-wrap: wrap; }
	}
</style>
