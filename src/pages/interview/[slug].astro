---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
	const interviews = await getCollection('interviews');
	return interviews.map(entry => ({
		params: { slug: entry.id },
		props: { entry, allInterviews: interviews },
	}));
}

const { entry, allInterviews } = Astro.props;
const { Content } = await render(entry);

const description = entry.data.summary
	?? `${entry.data.company} ${entry.data.position}${entry.data.round ? ' ' + entry.data.round : ''} 真实面经，涵盖${entry.data.tags.slice(0, 4).join('、')}等考点。`;

// 相关推荐：同公司 or 同岗位，排除自身，最多 5 篇
const related = allInterviews
	.filter(i => i.id !== entry.id && (i.data.company === entry.data.company || i.data.position === entry.data.position))
	.sort((a, b) => b.data.date.localeCompare(a.data.date))
	.slice(0, 5);

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "Article",
	"headline": entry.data.title,
	"description": description,
	"datePublished": entry.data.date + "-01",
	"author": { "@type": "Organization", "name": "面灵面经" },
	"publisher": {
		"@type": "Organization",
		"name": "面灵AI",
		"url": "https://mianlingai.com",
	},
	"keywords": [entry.data.company, entry.data.position, ...entry.data.tags].join(', '),
	"url": `${Astro.site}interview/${entry.id}`,
};
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead
			title={`${entry.data.title} — ${entry.data.company}面试真题`}
			description={description}
		/>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>
	<body>
		<Header />
		<main>
			<article>
				<div class="breadcrumb">
					<a href="/">首页</a>
					<span>/</span>
					<a href={`/company/${entry.data.company}`}>{entry.data.company}</a>
					<span>/</span>
					<span>{entry.data.title}</span>
				</div>

				<div class="article-header">
					<h1>{entry.data.title}</h1>
					<div class="meta">
						<a href={`/company/${entry.data.company}`} class="company">{entry.data.company}</a>
						<span class="sep">·</span>
						<a href={`/position/${entry.data.position}`} class="position">{entry.data.position}</a>
						{entry.data.round && (
							<>
								<span class="sep">·</span>
								<span>{entry.data.round}</span>
							</>
						)}
						{entry.data.base && (
							<>
								<span class="sep">·</span>
								<span>{entry.data.base}</span>
							</>
						)}
						<span class="sep">·</span>
						<span class="date">{entry.data.date}</span>
					</div>
					{entry.data.tags.length > 0 && (
						<div class="tags">
							{entry.data.tags.map(tag => (
								<a href={`/tag/${tag}`} class="tag">{tag}</a>
							))}
						</div>
					)}
				</div>

				<div class="content">
					<Content />
				</div>

				<div class="article-footer">
					<a href="https://mianlingai.com" target="_blank" rel="noopener" class="cta-banner">
						<div class="cta-content">
							<strong>面灵AI — AI实时面试助手</strong>
							<span>实时语音识别 + AI智能回答，轻松应对 {entry.data.company} 等大厂面试</span>
						</div>
						<span class="cta-arrow">→</span>
					</a>
				</div>

				{related.length > 0 && (
					<div class="related">
						<h2>相关面经</h2>
						<div class="related-list">
							{related.map(item => (
								<a href={`/interview/${item.id}`} class="related-item">
									<span class="related-title">{item.data.title}</span>
									<span class="related-meta">{item.data.company} · {item.data.position}{item.data.round ? ' · ' + item.data.round : ''}</span>
								</a>
							))}
						</div>
					</div>
				)}
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 800px;
		margin: 0 auto;
		padding: var(--space-md) 2rem var(--space-lg);
	}

	.breadcrumb {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.85rem;
		color: var(--color-muted);
		margin-bottom: var(--space-md);
	}
	.breadcrumb a:hover { color: var(--color-accent); }

	.article-header {
		margin-bottom: var(--space-md);
		padding-bottom: var(--space-md);
		border-bottom: 1px solid var(--color-border);
	}

	.article-header h1 {
		font-size: 1.75rem;
		font-weight: 700;
		margin-bottom: var(--space-sm);
		line-height: 1.3;
	}

	.meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.9rem;
		color: var(--color-muted);
		flex-wrap: wrap;
		margin-bottom: 0.75rem;
	}

	.company, .position { font-weight: 600; color: var(--color-accent); }
	.company:hover, .position:hover { text-decoration: underline; }
	.sep { color: var(--color-border); }

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
	}

	.tag {
		padding: 0.2rem 0.65rem;
		background: var(--color-card);
		border: 1px solid var(--color-border);
		border-radius: 20px;
		font-size: 0.8rem;
		color: var(--color-text);
		transition: all 0.15s;
	}
	.tag:hover {
		background: var(--color-accent);
		color: white;
		border-color: var(--color-accent);
	}

	.content { line-height: 1.8; font-size: 0.95rem; }
	.content :global(h2) { font-size: 1.4rem; margin-top: var(--space-md); margin-bottom: var(--space-sm); font-weight: 700; }
	.content :global(h3) { font-size: 1.15rem; margin-top: 1.5rem; margin-bottom: var(--space-xs); font-weight: 600; }
	.content :global(p) { margin-bottom: var(--space-sm); }
	.content :global(ul), .content :global(ol) { margin: var(--space-sm) 0; padding-left: 1.5rem; }
	.content :global(li) { margin-bottom: 0.5rem; }
	.content :global(pre) { background: var(--color-card); border: 1px solid var(--color-border); border-radius: 6px; padding: 1rem; overflow-x: auto; margin: var(--space-sm) 0; }
	.content :global(code) { font-family: monospace; font-size: 0.9em; }
	.content :global(strong) { font-weight: 600; }
	.content :global(hr) { border: none; border-top: 1px solid var(--color-border); margin: var(--space-md) 0; }

	.article-footer {
		margin-top: var(--space-lg);
		padding-top: var(--space-md);
		border-top: 1px solid var(--color-border);
	}

	.cta-banner {
		display: flex;
		justify-content: space-between;
		align-items: center;
		background: #fff5f0;
		border: 1px solid #ffd8c8;
		border-radius: 8px;
		padding: 1.25rem 1.5rem;
		transition: all 0.2s ease;
	}
	.cta-banner:hover { border-color: var(--color-accent); box-shadow: 0 4px 12px rgba(212, 56, 13, 0.1); }
	.cta-content { display: flex; flex-direction: column; gap: 0.25rem; }
	.cta-content strong { color: var(--color-accent); font-size: 1rem; }
	.cta-content span { color: var(--color-muted); font-size: 0.85rem; }
	.cta-arrow { font-size: 1.5rem; color: var(--color-accent); }

	.related {
		margin-top: var(--space-lg);
		padding-top: var(--space-md);
		border-top: 1px solid var(--color-border);
	}

	.related h2 { font-size: 1.15rem; font-weight: 700; margin-bottom: var(--space-sm); }

	.related-list { display: flex; flex-direction: column; }

	.related-item {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		padding: 0.75rem 0;
		border-bottom: 1px solid var(--color-border);
		transition: padding-left 0.15s;
	}
	.related-item:hover { padding-left: 0.5rem; }

	.related-title { font-size: 0.95rem; font-weight: 600; color: var(--color-text); }
	.related-meta { font-size: 0.82rem; color: var(--color-muted); }

	@media (max-width: 768px) {
		main { padding: var(--space-sm) 1rem; }
		.meta { flex-wrap: wrap; }
		.cta-banner { flex-direction: column; gap: 0.75rem; align-items: flex-start; }
	}
</style>
