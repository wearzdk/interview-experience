---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
	const interviews = await getCollection('interviews');
	return interviews.map(entry => ({
		params: { slug: entry.id },
		props: { entry, allInterviews: interviews },
	}));
}

const { entry, allInterviews } = Astro.props;
const { Content } = await render(entry);

const description = entry.data.summary
	?? `${entry.data.company} ${entry.data.position}${entry.data.round ? ' ' + entry.data.round : ''} 真实面经，涵盖${entry.data.tags.slice(0, 4).join('、')}等考点。`;

// 相关推荐：打分机制，同公司+2、同岗位+1、每个相同tag+1，取前5
const currentTags = new Set(entry.data.tags);
const related = allInterviews
	.filter(i => i.id !== entry.id)
	.map(i => {
		let score = 0;
		if (i.data.company === entry.data.company) score += 2;
		if (i.data.position === entry.data.position) score += 1;
		score += i.data.tags.filter(t => currentTags.has(t)).length;
		return { ...i, score };
	})
	.filter(i => i.score > 0)
	.sort((a, b) => b.score - a.score || b.data.date.localeCompare(a.data.date))
	.slice(0, 5);

const jsonLd = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "Article",
			"headline": entry.data.title,
			"description": description,
			"datePublished": entry.data.date + "-01",
			"author": { "@type": "Organization", "name": "面灵面经" },
			"publisher": {
				"@type": "Organization",
				"name": "面灵AI",
				"url": "https://www.mianlingai.com",
			},
			"keywords": [entry.data.company, entry.data.position, ...entry.data.tags].join(', '),
			"url": `${Astro.site}interview/${entry.id}`,
			"mentions": {
				"@type": "SoftwareApplication",
				"name": "面灵AI",
				"url": "https://www.mianlingai.com",
				"description": "实时面试辅助工具，面试中实时提供答案参考和编程题解答"
			}
		},
		{
			"@type": "BreadcrumbList",
			"itemListElement": [
				{ "@type": "ListItem", "position": 1, "name": "首页", "item": `${Astro.site}` },
				{ "@type": "ListItem", "position": 2, "name": entry.data.company, "item": `${Astro.site}company/${entry.data.company}` },
				{ "@type": "ListItem", "position": 3, "name": entry.data.title }
			]
		}
	]
};
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead
			title={`${entry.data.title} — ${entry.data.company}面试真题`}
			description={description}
		/>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	</head>
	<body>
		<Header />
		<main>
			<article>
				<div class="breadcrumb">
					<a href="/">首页</a>
					<span>/</span>
					<a href={`/company/${entry.data.company}`}>{entry.data.company}</a>
					<span>/</span>
					<span>{entry.data.title}</span>
				</div>

				<div class="article-header">
					<h1>{entry.data.title}</h1>
					<div class="meta">
						<a href={`/company/${entry.data.company}`} class="company">{entry.data.company}</a>
						<span class="sep">·</span>
						<a href={`/position/${entry.data.position}`} class="position">{entry.data.position}</a>
						{entry.data.round && (
							<>
								<span class="sep">·</span>
								<span>{entry.data.round}</span>
							</>
						)}
						{entry.data.base && (
							<>
								<span class="sep">·</span>
								<span>{entry.data.base}</span>
							</>
						)}
						<span class="sep">·</span>
						<span class="date">{entry.data.date}</span>
					</div>
					{entry.data.tags.length > 0 && (
						<div class="tags">
							{entry.data.tags.map(tag => (
								<a href={`/tag/${tag}`} class="tag">{tag}</a>
							))}
						</div>
					)}
				</div>

				<div class="content">
					<Content />
				</div>

				<div class="article-footer">
					<a href="https://mianlingai.com" target="_blank" rel="noopener" class="cta-banner">
						<div class="cta-content">
							<strong>面灵AI — AI实时面试助手</strong>
							<span>实时语音识别 + AI智能回答，轻松应对 {entry.data.company} 等大厂面试</span>
						</div>
						<span class="cta-arrow">→</span>
					</a>
				</div>

				{related.length > 0 && (
					<div class="related">
						<h2>相关面经</h2>
						<div class="related-list">
							{related.map(item => (
								<a href={`/interview/${item.id}`} class="related-item">
									<span class="related-title">{item.data.title}</span>
									<span class="related-meta">{item.data.company} · {item.data.position}{item.data.round ? ' · ' + item.data.round : ''}</span>
								</a>
							))}
						</div>
					</div>
				)}
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 760px;
		margin: 0 auto;
		padding: var(--space-md) 2rem var(--space-lg);
	}

	.breadcrumb {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.82rem;
		color: var(--color-muted);
		margin-bottom: var(--space-md);
	}
	.breadcrumb span { color: var(--color-border); }
	.breadcrumb a:hover { color: var(--color-accent); }

	.article-header {
		margin-bottom: var(--space-md);
		padding-bottom: 1.5rem;
	}

	.article-header h1 {
		font-size: 1.65rem;
		font-weight: 800;
		margin-bottom: 0.75rem;
		line-height: 1.35;
		letter-spacing: -0.02em;
	}

	.meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.85rem;
		color: var(--color-muted);
		flex-wrap: wrap;
		margin-bottom: 1rem;
	}

	.company, .position { font-weight: 600; color: var(--color-accent); }
	.company:hover, .position:hover { text-decoration: underline; }
	.sep { color: var(--color-border); }

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem;
	}

	.tag {
		padding: 0.2rem 0.6rem;
		background: var(--color-bg);
		border: none;
		border-radius: var(--radius-full);
		font-size: 0.78rem;
		color: var(--color-text-secondary);
	}
	.tag:hover {
		background: var(--color-accent);
		color: white;
	}

	.content {
		line-height: 1.85;
		font-size: 0.95rem;
		color: var(--color-text);
	}
	.content :global(h2) {
		font-size: 1.3rem;
		margin-top: 2.5rem;
		margin-bottom: 0.75rem;
		font-weight: 700;
		color: var(--color-text);
	}
	.content :global(h3) {
		font-size: 1.1rem;
		margin-top: 1.75rem;
		margin-bottom: var(--space-xs);
		font-weight: 600;
		color: var(--color-text);
	}
	.content :global(p) { margin-bottom: var(--space-sm); }
	.content :global(ul), .content :global(ol) { margin: var(--space-sm) 0; padding-left: 1.5rem; }
	.content :global(li) { margin-bottom: 0.4rem; }
	.content :global(pre) {
		background: var(--color-card);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-sm);
		padding: 1rem 1.25rem;
		overflow-x: auto;
		margin: var(--space-sm) 0;
		font-size: 0.88rem;
	}
	.content :global(code) { font-family: var(--font-mono); font-size: 0.88em; }
	.content :global(strong) { font-weight: 600; color: var(--color-text); }
	.content :global(hr) { border: none; border-top: 1px solid var(--color-border); margin: var(--space-md) 0; }
	.content :global(blockquote) {
		border-left: 3px solid var(--color-accent);
		padding-left: 1rem;
		margin: var(--space-sm) 0;
		color: var(--color-muted);
	}

	.article-footer {
		margin-top: var(--space-lg);
	}

	.cta-banner {
		display: flex;
		justify-content: space-between;
		align-items: center;
		background: var(--color-accent-light);
		border: 1px solid rgba(196, 57, 28, 0.12);
		border-radius: var(--radius-md);
		padding: 1.25rem 1.5rem;
	}
	.cta-banner:hover {
		border-color: var(--color-accent);
		box-shadow: var(--shadow-md);
	}
	.cta-content { display: flex; flex-direction: column; gap: 0.25rem; }
	.cta-content strong { color: var(--color-accent); font-size: 0.95rem; }
	.cta-content span { color: var(--color-muted); font-size: 0.82rem; }
	.cta-arrow { font-size: 1.25rem; color: var(--color-accent); transition: transform 0.15s ease; }
	.cta-banner:hover .cta-arrow { transform: translateX(3px); }

	.related {
		margin-top: var(--space-lg);
		padding-top: var(--space-md);
		border-top: 1px solid var(--color-border);
	}

	.related h2 {
		font-size: 1.05rem;
		font-weight: 700;
		margin-bottom: 0.75rem;
	}

	.related-list { display: flex; flex-direction: column; }

	.related-item {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		padding: 0.65rem 0.5rem;
		margin: 0 -0.5rem;
		border-radius: var(--radius-sm);
		transition: background 0.15s ease;
	}
	.related-item:not(:last-child) {
		border-bottom: 1px solid var(--color-border);
	}
	.related-item:hover {
		background: var(--color-card);
	}

	.related-title { font-size: 0.9rem; font-weight: 600; color: var(--color-text); }
	.related-meta { font-size: 0.8rem; color: var(--color-muted); }

	@media (max-width: 768px) {
		main { padding: var(--space-sm) 1rem; }
		.article-header h1 { font-size: 1.35rem; }
		.meta { flex-wrap: wrap; }
		.cta-banner { flex-direction: column; gap: 0.75rem; align-items: flex-start; }
	}
</style>
