---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
	const interviews = await getCollection('interviews');
	const positions = [...new Set(interviews.map(i => i.data.position))];
	
	return positions.map(position => ({
		params: { position },
		props: { 
			position,
			interviews: interviews.filter(i => i.data.position === position)
				.sort((a, b) => b.data.date.localeCompare(a.data.date))
		},
	}));
}

const { position, interviews } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`${position}面经`} description={`${position}真实面经分享`} />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>{position}</h1>
				<p>{interviews.length} 篇面经</p>
			</div>

			<div class="interview-list">
				{interviews.map(item => (
					<a href={`/interview/${item.id}`} class="list-item">
						<div class="item-main">
							<h3>{item.data.title}</h3>
							<div class="item-meta">
								<span class="company">{item.data.company}</span>
								{item.data.round && (
									<>
										<span class="sep">·</span>
										<span class="round">{item.data.round}</span>
									</>
								)}
							</div>
						</div>
						<span class="date">{item.data.date}</span>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 1200px;
		margin: 0 auto;
		padding: var(--space-md) 2rem var(--space-lg);
	}

	.page-header {
		margin-bottom: var(--space-md);
		padding-bottom: var(--space-sm);
		border-bottom: 2px solid var(--color-accent);
	}

	.page-header h1 {
		font-size: 1.75rem;
		font-weight: 700;
		margin-bottom: 0.25rem;
	}

	.page-header p {
		font-size: 0.9rem;
		color: var(--color-muted);
	}

	.interview-list {
		display: flex;
		flex-direction: column;
	}

	.list-item {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 0;
		border-bottom: 1px solid var(--color-border);
		transition: all 0.15s ease;
	}

	.list-item:hover {
		padding-left: 0.75rem;
		background: linear-gradient(90deg, rgba(212, 56, 13, 0.04) 0%, transparent 100%);
	}

	.item-main h3 {
		font-size: 1rem;
		font-weight: 600;
		margin-bottom: 0.35rem;
	}

	.item-meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.85rem;
		color: var(--color-muted);
	}

	.company {
		color: var(--color-accent);
		font-weight: 600;
	}

	.sep { color: var(--color-border); }

	.round {
		background: var(--color-text);
		color: white;
		padding: 0.1rem 0.5rem;
		border-radius: 3px;
		font-size: 0.75rem;
		font-weight: 600;
	}

	.date {
		font-size: 0.85rem;
		color: var(--color-muted);
		white-space: nowrap;
	}

	@media (max-width: 768px) {
		main { padding: var(--space-sm) 1rem; }
		.list-item { flex-direction: column; align-items: flex-start; gap: 0.25rem; }
	}
</style>
