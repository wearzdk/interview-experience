---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
	const interviews = await getCollection('interviews');
	const companies = [...new Set(interviews.map(i => i.data.company))];
	
	return companies.map(company => ({
		params: { company },
		props: { 
			company,
			interviews: interviews.filter(i => i.data.company === company)
				.sort((a, b) => b.data.date.localeCompare(a.data.date))
		},
	}));
}

const { company, interviews } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`${company}面经`} description={`${company}真实面经分享`} />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>{company}</h1>
				<p>{interviews.length} 篇面经</p>
			</div>

			<div class="interview-list">
				{interviews.map(item => (
					<a href={`/interview/${item.id}`} class="list-item">
						<div class="item-main">
							<h3>{item.data.title}</h3>
							<div class="item-meta">
								<span class="position">{item.data.position}</span>
								{item.data.round && (
									<>
										<span class="sep">·</span>
										<span class="round">{item.data.round}</span>
									</>
								)}
							</div>
						</div>
						<span class="date">{item.data.date}</span>
					</a>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 1200px;
		margin: 0 auto;
		padding: var(--space-md) 2rem var(--space-lg);
	}

	.page-header {
		margin-bottom: var(--space-md);
		padding-bottom: var(--space-sm);
	}

	.page-header h1 {
		font-size: 1.65rem;
		font-weight: 800;
		margin-bottom: 0.25rem;
		letter-spacing: -0.02em;
	}

	.page-header p {
		font-size: 0.85rem;
		color: var(--color-muted);
	}

	.interview-list {
		display: flex;
		flex-direction: column;
	}

	.list-item {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.875rem 0;
		border-bottom: 1px solid var(--color-border);
		transition: padding-left 0.15s ease;
	}

	.list-item:hover {
		padding-left: 0.5rem;
	}

	.item-main h3 {
		font-size: 0.95rem;
		font-weight: 600;
		margin-bottom: 0.3rem;
		line-height: 1.4;
	}

	.item-meta {
		display: flex;
		align-items: center;
		gap: 0.4rem;
		font-size: 0.8rem;
		color: var(--color-muted);
	}

	.position {
		color: var(--color-accent);
		font-weight: 600;
	}

	.sep { color: var(--color-border); font-size: 0.75rem; }

	.round {
		background: var(--color-accent-light);
		color: var(--color-accent);
		padding: 0.1rem 0.45rem;
		border-radius: var(--radius-sm);
		font-size: 0.72rem;
		font-weight: 600;
		margin-left: 0.25rem;
	}

	.date {
		font-size: 0.8rem;
		color: var(--color-muted);
		white-space: nowrap;
		flex-shrink: 0;
	}

	@media (max-width: 768px) {
		main { padding: var(--space-sm) 1rem; }
		.list-item {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.25rem;
			padding: 0.75rem;
		}
	}
</style>
