---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const interviews = await getCollection('interviews');
const latest = interviews.sort((a, b) => b.data.date.localeCompare(a.data.date)).slice(0, 20);
const companies = [...new Set(interviews.map(i => i.data.company))].sort();
const positions = [...new Set(interviews.map(i => i.data.position))].sort();
const hotTags = Object.entries(
	interviews.flatMap(i => i.data.tags).reduce((acc, t) => ({ ...acc, [t]: (acc[t] ?? 0) + 1 }), {} as Record<string, number>)
).sort((a, b) => b[1] - a[1]).slice(0, 15).map(([t]) => t);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-text">
					<h1>面灵面经</h1>
					<p>从牛客、脉脉等平台采集的真实互联网面经，已收录 <strong>{interviews.length}</strong> 篇</p>
				</div>
				<img src="/illustrations/interview.svg" alt="" class="hero-illustration" />
			</section>

			<section class="filters">
				<div class="filter-group">
					<h3>公司</h3>
					<div class="filter-tags">
						{companies.map(c => (
							<a href={`/company/${c}`}>{c}</a>
						))}
					</div>
				</div>
				<div class="filter-group">
					<h3>岗位</h3>
					<div class="filter-tags">
						{positions.map(p => (
							<a href={`/position/${p}`}>{p}</a>
						))}
					</div>
				</div>
				<div class="filter-group">
					<h3>技术点</h3>
					<div class="filter-tags">
						{hotTags.map(t => (
							<a href={`/tag/${t}`}>{t}</a>
						))}
					</div>
				</div>
			</section>

			<section class="list">
				<h2>最新面经</h2>
				<div class="interview-list">
					{latest.map(item => (
						<a href={`/interview/${item.id}`} class="list-item">
							<div class="item-main">
								<h3>{item.data.title}</h3>
								<div class="item-meta">
									<span class="company">{item.data.company}</span>
									<span class="sep">·</span>
									<span class="position">{item.data.position}</span>
									{item.data.round && (
										<>
											<span class="sep">·</span>
											<span class="round">{item.data.round}</span>
										</>
									)}
								</div>
								{item.data.summary && <p class="summary">{item.data.summary}</p>}
							</div>
							<span class="date">{item.data.date}</span>
						</a>
					))}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
	}

	/* Hero */
	.hero {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: var(--space-md) 0;
		gap: var(--space-md);
	}

	.hero-text h1 {
		font-size: 2rem;
		font-weight: 700;
		margin-bottom: 0.5rem;
	}

	.hero-text p {
		color: var(--color-muted);
		font-size: 0.95rem;
		line-height: 1.6;
	}

	.hero-text strong {
		color: var(--color-accent);
		font-weight: 700;
	}

	.hero-illustration {
		width: 200px;
		height: 150px;
		flex-shrink: 0;
	}

	/* 筛选区 */
	.filters {
		display: flex;
		gap: var(--space-lg);
		padding: var(--space-md) 0;
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
	}

	.filter-group h3 {
		font-size: 0.85rem;
		color: var(--color-muted);
		margin-bottom: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.05em;
	}

	.filter-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.filter-tags a {
		padding: 0.35rem 0.85rem;
		background: var(--color-card);
		border: 1px solid var(--color-border);
		border-radius: 20px;
		font-size: 0.85rem;
		color: var(--color-text);
		transition: all 0.2s ease;
	}

	.filter-tags a:hover {
		background: var(--color-accent);
		color: white;
		border-color: var(--color-accent);
	}

	/* 列表 */
	.list {
		padding: var(--space-md) 0 var(--space-lg);
	}

	.list h2 {
		font-size: 1.25rem;
		font-weight: 700;
		margin-bottom: var(--space-sm);
	}

	.interview-list {
		display: flex;
		flex-direction: column;
	}

	.list-item {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 0;
		border-bottom: 1px solid var(--color-border);
		transition: all 0.15s ease;
	}

	.list-item:hover {
		padding-left: 0.75rem;
		background: linear-gradient(90deg, rgba(212, 56, 13, 0.04) 0%, transparent 100%);
	}

	.item-main h3 {
		font-size: 1rem;
		font-weight: 600;
		margin-bottom: 0.35rem;
	}

	.item-meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.85rem;
		color: var(--color-muted);
	}

	.summary {
		font-size: 0.83rem;
		color: var(--color-muted);
		line-height: 1.5;
		margin: 0.35rem 0 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.company {
		color: var(--color-accent);
		font-weight: 600;
	}

	.sep {
		color: var(--color-border);
	}

	.round {
		background: var(--color-text);
		color: white;
		padding: 0.1rem 0.5rem;
		border-radius: 3px;
		font-size: 0.75rem;
		font-weight: 600;
	}

	.date {
		font-size: 0.85rem;
		color: var(--color-muted);
		white-space: nowrap;
	}

	@media (max-width: 768px) {
		main { padding: 0 1rem; }
		.hero-illustration { display: none; }
		.filters { flex-direction: column; gap: var(--space-sm); }
		.list-item { flex-direction: column; align-items: flex-start; gap: 0.25rem; }
	}
</style>
